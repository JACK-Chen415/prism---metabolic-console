# Prism Metabolic Console - Backend Environment Configuration

# 应用配置
APP_NAME=Prism Metabolic Console
APP_VERSION=1.0.0
DEBUG=false

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置 (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://prism:prism123@localhost:5433/prism_metabolic

# JWT 认证配置
JWT_SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 豆包 AI 配置 (Volcengine ARK)
# 请在火山引擎控制台获取
ARK_API_KEY=your_ark_api_key
# 主多模态模型 endpoint/model，文本和图片识别共用
DOUBAO_MODEL=ep-xxxxxxxxxx
# 业务级超时与重试，避免 SDK 默认长时间等待
DOUBAO_TIMEOUT_SECONDS=60
DOUBAO_CONNECT_TIMEOUT_SECONDS=10
DOUBAO_MAX_RETRIES=1
# 普通文本聊天与图片识别分别控制输出长度，不拆分模型
DOUBAO_CHAT_MAX_TOKENS=800
DOUBAO_VISION_MAX_TOKENS=2000
DOUBAO_VISION_FAST_MAX_TOKENS=900

# AI 聊天上下文保护
CHAT_HISTORY_LIMIT=12
CHAT_HISTORY_MESSAGE_MAX_CHARS=1200
CHAT_PROMPT_MAX_CHARS=12000

# 文件存储配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# CORS 配置 (生产环境请修改为你的前端域名)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
